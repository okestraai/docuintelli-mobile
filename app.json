{
  "expo": {
    "name": "DocuIntelli AI",
    "slug": "docuintelli",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#059669"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.docuintelli.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "DocuIntelli needs camera access to scan documents",
        "NSPhotoLibraryUsageDescription": "DocuIntelli needs photo library access to attach images to your documents",
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock DocuIntelli",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#064e3b"
      },
      "package": "com.docuintelli.app",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "scheme": "docuintelli",
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-document-picker",
      "expo-local-authentication",
      "expo-notifications",
      "expo-sqlite",
      "expo-asset",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "0ad81a6e-b653-42f6-98c0-c1ed7fbb8b47"
      },
      "router": {}
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "okestraai",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/0ad81a6e-b653-42f6-98c0-c1ed7fbb8b47"
    }
  }
}
