{
  "expo": {
    "name": "DocuIntelli AI",
    "slug": "docuintelli",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#059669"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.docuintelli.app",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:docuintelli.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "DocuIntelli needs camera access to scan documents",
        "NSPhotoLibraryUsageDescription": "DocuIntelli needs photo library access to attach images to your documents",
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock DocuIntelli",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPinnedDomains": {
          "docuintelli.com": {
            "NSIncludesSubdomains": false,
            "NSPinnedLeafIdentities": [
              {
                "SPKI-SHA256-BASE64": "sATf4+jHZQLPTTG7MKMCLS6/UYx+tUflX6i5zhlJgKI="
              }
            ],
            "NSPinnedCAIdentities": [
              {
                "SPKI-SHA256-BASE64": "kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4="
              }
            ]
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#064e3b"
      },
      "package": "com.docuintelli.app",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "docuintelli.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "scheme": "docuintelli",
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-document-picker",
      "expo-local-authentication",
      "expo-notifications",
      "expo-sqlite",
      "expo-asset",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-updates"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8ed00e57-83f4-4199-8470-5913cdc57e39"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "nobledeveloper",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8ed00e57-83f4-4199-8470-5913cdc57e39"
    }
  }
}
